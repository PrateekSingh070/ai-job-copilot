# Server
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/copilot
JWT_ACCESS_SECRET=replace_with_32plus_char_secret
JWT_REFRESH_SECRET=replace_with_32plus_char_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# OAuth — add redirect URIs in Google Cloud Console and GitHub OAuth App:
#   http://localhost:4000/auth/oauth/google/callback
#   http://localhost:4000/auth/oauth/github/callback
FRONTEND_URL=http://localhost:5173
SERVER_PUBLIC_URL=http://localhost:4000
OAUTH_STATE_SECRET=replace_with_a_long_random_secret_min_16_chars
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
AI_MAX_INPUT_CHARS=4000
AI_MAX_OUTPUT_TOKENS_RESUME=450
AI_MAX_OUTPUT_TOKENS_COVER=550
AI_MAX_OUTPUT_TOKENS_INTERVIEW=700
AI_RATE_LIMIT_PER_MINUTE=8
REDIS_URL=redis://localhost:6379
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
SENTRY_DSN=

# Client (leave empty when the API is served from the same origin as the SPA, e.g. Docker/production)
VITE_API_URL=http://localhost:4000

# Production (Docker / single host): path to Vite build output; set automatically in Dockerfile
# CLIENT_STATIC_DIR=/app/client/dist
