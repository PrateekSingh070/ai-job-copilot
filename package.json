{
  "name": "ai-job-application-copilot",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "npm-run-all -p dev:server dev:client",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "build": "npm-run-all build:shared build:server build:client build:extension",
    "build:shared": "npm --prefix shared run build",
    "build:server": "npm --prefix server run build",
    "build:client": "npm --prefix client run build",
    "build:extension": "npm --prefix extension run build",
    "lint": "npm-run-all lint:shared lint:server lint:client",
    "lint:shared": "npm --prefix shared run lint",
    "lint:server": "npm --prefix server run lint",
    "lint:client": "npm --prefix client run lint",
    "test": "npm-run-all test:server test:client",
    "test:server": "npm --prefix server run test",
    "test:client": "npm --prefix client run test",
    "e2e:doctor": "node scripts/e2e-doctor.mjs",
    "test:e2e": "playwright test",
    "typecheck": "npm-run-all typecheck:shared typecheck:server typecheck:client typecheck:extension",
    "typecheck:shared": "npx tsc -p shared/tsconfig.json --noEmit",
    "typecheck:server": "npx tsc -p server/tsconfig.json --noEmit",
    "typecheck:client": "npx tsc -p client/tsconfig.json --noEmit",
    "typecheck:extension": "npx tsc -p extension/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.59.1",
    "prettier": "^3.6.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write"
    ],
    "server/src/**/*.{ts,tsx}": [
      "npm --prefix server run lint -- --fix"
    ],
    "server/src/**/*.test.{ts,tsx}": [
      "npm --prefix server run test -- --run"
    ],
    "client/src/**/*.{ts,tsx}": [
      "npm --prefix client run lint -- --fix"
    ],
    "client/src/**/*.test.{ts,tsx}": [
      "npm --prefix client run test -- --run"
    ]
  }
}
